# =========================================================
# Interview IQ environment configuration
# Copy this file to apps/api/.env and fill real values.
# Never commit a real .env file.
# =========================================================

# ---------- Runtime ----------
NODE_ENV=development
PORT=4000
# Comma separated list of allowed browser origins (the Next.js app).
CORS_ORIGIN=http://localhost:3000

# ---------- Database (Prisma against Supabase Postgres) ----------
# Pooled connection used by the app at runtime.
# Supabase: Project Settings, Database, Connection string, URI (transaction pooler, port 6543).
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Direct connection used only by Prisma migrate (port 5432, no pooler).
DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# ---------- File storage ----------
# When SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are set, resumes go to Supabase Storage.
# If they are left blank, the app falls back to local disk (LOCAL_STORAGE_DIR) so it runs offline.
SUPABASE_URL=https://PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=resumes
LOCAL_STORAGE_DIR=.storage

# ---------- Auth (custom JWT) ----------
# Generate each secret with: openssl rand -base64 48
# Required to be at least 32 characters in production.
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- AI provider ----------
# openai or mock. Set to mock to run the full flow with zero external keys.
AI_PROVIDER=mock
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# ---------- Uploads ----------
MAX_FILE_SIZE_MB=5

# ---------- Rate limiting ----------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# =========================================================
# Frontend (apps/web). Copy to apps/web/.env.local.
# Only NEXT_PUBLIC_ values reach the browser.
# =========================================================
NEXT_PUBLIC_API_URL=http://localhost:4000
