// Interview IQ database schema.
// PostgreSQL via Supabase in test, AWS RDS Postgres in production (same dialect).
// Row Level Security is intentionally disabled: the API is the only DB client and
// enforces ownership at the service layer. See CLAUDE.md for the full rationale.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Seniority {
  junior
  mid
  senior
  lead
  principal
}

enum InterviewStatus {
  setup
  in_progress
  completed
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String
  name         String
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  refreshTokens RefreshToken[]
  resumes       Resume[]
  profiles      Profile[]
  interviews    Interview[]

  @@unique([email])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Resume {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  filename    String
  mimeType    String    @map("mime_type")
  sizeBytes   Int       @map("size_bytes")
  storagePath String    @map("storage_path")
  rawText     String?   @map("raw_text")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile Profile?

  @@index([userId])
  @@map("resumes")
}

model Profile {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  resumeId   String   @unique @map("resume_id") @db.Uuid
  summary    String
  skills     String[]
  experience Json     @default("[]")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  editedAt   DateTime @updatedAt @map("edited_at") @db.Timestamptz(6)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume     Resume      @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  interviews Interview[]

  @@index([userId])
  @@map("profiles")
}

model Interview {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  profileId      String          @map("profile_id") @db.Uuid
  role           String
  seniority      Seniority
  jobDescription String?         @map("job_description")
  status         InterviewStatus @default(setup)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz(6)

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile    Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  questions  Question[]
  answers    Answer[]
  assessment Assessment?

  @@index([userId])
  @@index([profileId])
  @@map("interviews")
}

model Question {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId String @map("interview_id") @db.Uuid
  order       Int
  text        String

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  answer    Answer?

  @@unique([interviewId, order])
  @@index([interviewId])
  @@map("questions")
}

model Answer {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId String   @map("interview_id") @db.Uuid
  questionId  String   @unique @map("question_id") @db.Uuid
  text        String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  question  Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([interviewId, questionId])
  @@index([interviewId])
  @@map("answers")
}

model Assessment {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  interviewId           String   @unique @map("interview_id") @db.Uuid
  overallScore          Int      @map("overall_score")
  relevanceScore        Int      @map("relevance_score")
  clarityScore          Int      @map("clarity_score")
  structureScore        Int      @map("structure_score")
  communicationScore    Int      @map("communication_score")
  strengths             String[]
  improvements          String[]
  improvedExample       Json     @map("improved_example")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("assessments")
}
